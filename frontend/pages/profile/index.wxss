/* 个人中心页面样式 */
.profile-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 顶部导航栏 */
.top-bar {
  height: 80rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  position: relative;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  flex: 1;
  text-align: center;
}

.edit-btn {
  padding: 8rpx 16rpx;
  border: 1rpx solid #ff6b35;
  border-radius: 16rpx;
  background-color: transparent;
  color: #ff6b35;
  font-size: 22rpx;
}

/* 内容滚动区 */
.content-scroll {
  flex: 1;
  padding-bottom: 40rpx;
}

.profile-content {
  padding: 30rpx;
}

/* 用户卡片 */
.user-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background-color: #f0f0f0;
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
  display: block;
}

.user-area {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 4rpx;
  display: block;
}

.user-since {
  font-size: 20rpx;
  color: #999999;
  display: block;
}

.user-id-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #f8f8f8;
  padding: 15rpx 20rpx;
  border-radius: 8rpx;
}

.user-id-label {
  font-size: 22rpx;
  color: #666666;
}

.copy-tip {
  font-size: 18rpx;
  color: #ff6b35;
}

/* 统计卡片 */
.stats-grid {
  display: flex;
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  border-right: 1rpx solid #f0f0f0;
}

.stat-item:last-child {
  border-right: none;
}

.stat-number {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b35;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 20rpx;
  color: #666666;
}

/* 社交数据卡片 */
.social-stats {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.social-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.social-item:last-child {
  border-bottom: none;
}

.social-label {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
}

.social-values {
  display: flex;
  gap: 15rpx;
}

.social-value {
  font-size: 22rpx;
  color: #409eff;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.action-btn {
  width: calc(50% - 8rpx);
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.action-btn:active {
  transform: scale(0.98);
}

.action-text {
  font-size: 22rpx;
  color: #666666;
}

/* 标签切换 */
.tab-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.tab-header {
  display: flex;
  height: 80rpx;
  border-bottom: 1rpx solid #eeeeee;
}

.tab-btn {
  flex: 1;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f8f8f8;
  color: #666666;
  font-size: 26rpx;
  position: relative;
}

.tab-btn.active {
  background-color: #ffffff;
  color: #ff6b35;
  font-weight: bold;
}

.tab-count {
  position: absolute;
  top: 15rpx;
  right: 25rpx;
  min-width: 25rpx;
  height: 25rpx;
  background-color: #f56c6c;
  color: #ffffff;
  font-size: 16rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

/* 评价容器 */
.reviews-container {
  max-height: 600rpx;
  overflow-y: auto;
}

.review-item {
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.review-item:last-child {
  border-bottom: none;
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.review-info {
  flex: 1;
}

.review-rating {
  font-size: 22rpx;
  color: #ff6b35;
  margin-bottom: 4rpx;
  display: block;
}

.review-target, .review-author {
  font-size: 18rpx;
  color: #999999;
  display: block;
}

.delete-btn {
  padding: 4rpx 12rpx;
  border: 1rpx solid #f56c6c;
  border-radius: 12rpx;
  background-color: transparent;
  color: #f56c6c;
  font-size: 18rpx;
}

.review-content {
  font-size: 24rpx;
  color: #333333;
  line-height: 1.4;
  margin-bottom: 12rpx;
  display: block;
}

.review-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.tag {
  padding: 2rpx 8rpx;
  background-color: rgba(255, 107, 53, 0.1);
  color: #ff6b35;
  font-size: 16rpx;
  border-radius: 8rpx;
}

.review-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.review-time {
  font-size: 18rpx;
  color: #999999;
}

.review-likes {
  font-size: 18rpx;
  color: #409eff;
}

/* 空评价状态 */
.empty-reviews {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 12rpx;
  text-align: center;
}

.empty-tip {
  font-size: 22rpx;
  color: #cccccc;
  text-align: center;
}

/* 底部设置 */
.settings-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.logout-btn {
  width: 100%;
  padding: 20rpx;
  background-color: transparent;
  color: #f56c6c;
  font-size: 26rpx;
  font-weight: 500;
  border: 1rpx solid rgba(245, 108, 108, 0.2);
}

/* 加载状态 */
.loading {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15rpx;
  background-color: rgba(255, 255, 255, 0.9);
  padding: 40rpx;
  border-radius: 10rpx;
  z-index: 300;
}

.loading-text {
  color: #666666;
  font-size: 24rpx;
}

/* 提示信息 */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: rgba(0, 0, 0, 0.8);
  color: #ffffff;
  padding: 20rpx 30rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  z-index: 400;
  opacity: 0;
  animation: toastShow 2s ease-in-out;
}

.toast-text {
  color: #ffffff;
  text-align: center;
}

@keyframes toastShow {
  0% { opacity: 0; }
  20% { opacity: 1; }
  80% { opacity: 1; }
  100% { opacity: 0; }
}

/* 评分星号样式 */
.review-rating {
  font-size: 22rpx;
  color: #ff6b35;
}

/* 占位符样式，确保不显示undefined */
.review-rating:empty::before {
  content: '☆☆☆☆☆';
  color: #cccccc;
}