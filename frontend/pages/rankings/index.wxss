/* 排行榜页面样式 */
.rankings-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 顶部导航栏 */
.top-bar {
  height: 80rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  position: relative;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: rgba(255, 107, 53, 0.1);
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  flex: 1;
  text-align: center;
}

.placeholder {
  width: 60rpx;
}

/* 时间周期选择器 */
.period-selector {
  display: flex;
  background-color: #ffffff;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.period-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #666666;
  font-size: 26rpx;
  position: relative;
  border-bottom: 3rpx solid transparent;
}

.period-btn.active {
  color: #ff6b35;
  border-bottom-color: #ff6b35;
  font-weight: 500;
}

/* 标签切换 */
.tab-selector {
  display: flex;
  background-color: #ffffff;
  margin: 20rpx 30rpx 0 30rpx;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab-btn {
  flex: 1;
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #f8f8f8;
  color: #666666;
  font-size: 28rpx;
  gap: 4rpx;
}

.tab-btn.active {
  background-color: #ff6b35;
  color: #ffffff;
}

.tab-desc {
  font-size: 20rpx;
  opacity: 0.8;
}

/* 排行榜滚动区域 */
.rankings-scroll {
  flex: 1;
  padding: 0 30rpx 30rpx 30rpx;
}

.rankings-content {
  padding-top: 20rpx;
}

/* 前三名特殊样式 */
.top-three-section {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  margin-bottom: 30rpx;
}

.top-ranker {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 25rpx 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
  position: relative;
}

.top-ranker.rank-1 {
  background: linear-gradient(135deg, #ffd700, #ffed4a);
  border: 2rpx solid #ffd700;
}

.top-ranker.rank-2 {
  background: linear-gradient(135deg, #c0c0c0, #e5e5e5);
  border: 2rpx solid #c0c0c0;
}

.top-ranker.rank-3 {
  background: linear-gradient(135deg, #cd7f32, #e2a76f);
  border: 2rpx solid #cd7f32;
}

.rank-number {
  position: absolute;
  top: -10rpx;
  left: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: #ff6b35;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.ranker-avatar {
  width: 80rpx;
  height: 80rpx;
  position: relative;
  margin-right: 20rpx;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #f0f0f0;
}

.rank-badge {
  position: absolute;
  bottom: -5rpx;
  right: -5rpx;
  width: 30rpx;
  height: 30rpx;
  background-color: #ff6b35;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
  font-weight: bold;
  border: 2rpx solid #ffffff;
}

.ranker-photo {
  width: 80rpx;
  height: 80rpx;
  position: relative;
  margin-right: 20rpx;
}

.photo-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  background-color: #f0f0f0;
}

.ranker-info {
  flex: 1;
}

.ranker-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 6rpx;
  display: block;
}

.store-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 4rpx;
  display: block;
}

.store-area {
  font-size: 20rpx;
  color: #666666;
  margin-bottom: 6rpx;
  display: block;
}

.ranker-stats {
  font-size: 20rpx;
  color: #666666;
  margin-bottom: 4rpx;
  display: block;
}

.store-stats {
  font-size: 20rpx;
  color: #666666;
  display: block;
}

.ranker-likes {
  font-size: 18rpx;
  color: #409eff;
  display: block;
}

.rank-trend {
  text-align: center;
}

.trend-text {
  font-size: 22rpx;
  font-weight: bold;
}

.trend-text.up {
  color: #67c23a;
}

.trend-text.down {
  color: #f56c6c;
}

.trend-text.stable {
  color: #999999;
}

/* 普通排名项 */
.other-rankers {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.normal-ranker {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.normal-rank-number {
  font-size: 24rpx;
  font-weight: bold;
  color: #666666;
  width: 40rpx;
  margin-right: 16rpx;
}

.normal-avatar {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  margin-right: 15rpx;
  background-color: #f0f0f0;
}

.normal-store-photo {
  width: 50rpx;
  height: 50rpx;
  border-radius: 8rpx;
  margin-right: 15rpx;
  background-color: #f0f0f0;
}

.normal-rank-info {
  flex: 1;
}

.normal-rank-name {
  font-size: 22rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 4rpx;
  display: block;
}

.normal-store-name {
  font-size: 22rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 2rpx;
  display: block;
}

.normal-store-area {
  font-size: 16rpx;
  color: #999999;
  margin-bottom: 4rpx;
  display: block;
}

.normal-rank-stats {
  font-size: 16rpx;
  color: #999999;
  display: block;
}

.normal-store-stats {
  font-size: 16rpx;
  color: #999999;
  display: block;
}

.normal-rank-likes {
  font-size: 18rpx;
  color: #409eff;
}

.normal-store-likes {
  font-size: 18rpx;
  color: #409eff;
}

/* 空状态 */
.empty-rankings {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 20rpx 0;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.7;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 12rpx;
  text-align: center;
}

.empty-tip {
  font-size: 22rpx;
  color: #cccccc;
  text-align: center;
}

/* 加载状态 */
.loading {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15rpx;
  background-color: rgba(255, 255, 255, 0.9);
  padding: 40rpx;
  border-radius: 10rpx;
  z-index: 300;
}

.loading-text {
  color: #666666;
  font-size: 24rpx;
}

/* 提示信息 */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: rgba(0, 0, 0, 0.8);
  color: #ffffff;
  padding: 20rpx 30rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  z-index: 400;
  opacity: 0;
  animation: toastShow 2s ease-in-out;
}

.toast-text {
  color: #ffffff;
  text-align: center;
}

@keyframes toastShow {
  0% { opacity: 0; }
  20% { opacity: 1; }
  80% { opacity: 1; }
  100% { opacity: 0; }
}

/* 排行榜渐变背景效果 */
.top-ranker.rank-1 {
  background: linear-gradient(135deg, #ffd700, #ffe066);
  box-shadow: 0 4rpx 16rpx rgba(255, 215, 0, 0.3);
}

.top-ranker.rank-2 {
  background: linear-gradient(135deg, #e8e8e8, #f5f5f5);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.top-ranker.rank-3 {
  background: linear-gradient(135deg, #deb887, #f4d08c);
  box-shadow: 0 4rpx 16rpx rgba(205, 127, 50, 0.2);
}