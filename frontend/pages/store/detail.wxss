/* 店铺场景页面样式 */
.store-scene-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #000000;
  position: relative;
}

.top-bar {
  height: 80rpx;
  background-color: rgba(255, 107, 53, 0.9);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-sizing: border-box;
  z-index: 100;
  position: relative;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.2);
}

.store-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.store-name {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 4rpx;
}

.online-count {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

.actions {
  display: flex;
  gap: 15rpx;
}

.action-btn {
  width: 60rpx;
  height: 60rpx;
  border: none;
  background-color: rgba(0, 0, 0, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ========== v6.0 场景样式 ========== */

/* 场景外层容器：填充顶部栏到互动栏之间的剩余空间 */
.scene-area {
  flex: 1;
  position: relative;
  overflow: hidden;
}

/* 场景可滚动区域 */
.scene-scroll {
  width: 100%;
  height: 100%;
  background-color: #000000;
}

/* 场景容器：relative 定位，供热区 absolute 参照 */
.scene-wrapper {
  position: relative;
  width: 100%;
}

/* 一体化背景图 */
.scene-bg {
  width: 100%;
  display: block;
}

/* 热区：绝对定位，百分比坐标 */
.hotspot {
  position: absolute;
  /* 开发阶段显示半透明边框辅助定位 */
}

/* 调试热区边框（上线前注释掉下面一行） */
.hotspot-debug {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border: 2rpx dashed rgba(255, 107, 53, 0.4);
  background: rgba(255, 107, 53, 0.08);
  border-radius: 6rpx;
  pointer-events: none;
}

/* 对话气泡 */
.chat-bubble {
  position: absolute;
  bottom: 100%;
  left: 50%;
  transform: translateX(-50%);
  margin-bottom: 10rpx;
  padding: 12rpx 22rpx;
  background: #ffffff;
  color: #333333;
  font-size: 24rpx;
  border-radius: 16rpx 16rpx 4rpx 16rpx;
  white-space: nowrap;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.18);
  z-index: 100;
  animation: bubbleFadeInOut 3s ease forwards;
  pointer-events: none;
}

/* 气泡三角箭头 */
.chat-bubble::after {
  content: '';
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 10rpx solid #ffffff;
}

.bubble-text {
  font-family: -apple-system, 'Helvetica Neue', sans-serif;
  line-height: 1.3;
}

/* 发言计数标签（阿拉伯数字常驻） */
.chat-count-badge {
  position: absolute;
  top: -32rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #ff6b35;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: bold;
  min-width: 30rpx;
  height: 30rpx;
  line-height: 30rpx;
  text-align: center;
  border-radius: 15rpx;
  padding: 0 8rpx;
  z-index: 40;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 53, 0.4);
}

.count-text {
  font-family: monospace;
}

/* ========== Demo 群聊浮动叠加层 ========== */

.demo-chat-overlay {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  bottom: 8rpx;
  max-height: 280rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  z-index: 50;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  pointer-events: auto;
}

.demo-chat-header {
  height: 48rpx;
  padding: 0 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff8f5;
  border-bottom: 1rpx solid #ffebdd;
  flex-shrink: 0;
}

.demo-chat-title {
  font-size: 20rpx;
  font-weight: 600;
  color: #ff6b35;
}

.demo-chat-count {
  font-size: 18rpx;
  color: #999;
}

.demo-chat-list {
  height: 232rpx; /* 280(overlay) - 48(header) = 显式高度，scroll-y 生效 */
  padding: 8rpx 16rpx;
}

.demo-chat-item {
  padding: 6rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.demo-chat-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2rpx;
}

.demo-chat-sender {
  font-size: 20rpx;
  font-weight: 600;
  color: #333;
}

.demo-chat-time {
  font-size: 16rpx;
  color: #ccc;
}

.demo-chat-content {
  font-size: 22rpx;
  color: #555;
  line-height: 1.4;
  word-break: break-all;
}

@keyframes bubbleFadeInOut {
  0%   { opacity: 0; transform: translateX(-50%) translateY(12rpx); }
  12%  { opacity: 1; transform: translateX(-50%) translateY(0); }
  75%  { opacity: 1; transform: translateX(-50%) translateY(0); }
  100% { opacity: 0; transform: translateX(-50%) translateY(-10rpx); }
}

