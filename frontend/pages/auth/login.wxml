<view class="login-container">
  <!-- Logo和标题 -->
  <view class="header">
    <image class="logo" src="../../images/logo.png" mode="aspectFit" />
    <text class="app-name">食遇</text>
    <text class="app-slogan">美食社交，相遇美好</text>
  </view>
  
  <!-- 登录表单 -->
  <view class="login-form">
    <button 
      class="wechat-login-btn" 
      type="primary" 
      size="default"
      bindtap="onWechatLogin"
    >
      <icon type="wechat" size="20" color="#fff" class="wechat-icon"></icon>
      微信一键登录
    </button>
    
    <text class="tips">
      使用微信账号登录，快速加入美食社交
    </text>
    
    <view class="features">
      <view class="feature-item">
        <icon type="location" size="24" color="#ff6b35"></icon>
        <text class="feature-text">实时群聊</text>
      </view>
      
      <view class="feature-item">
        <icon type="photo" size="24" color="#ff6b35"></icon>
        <text class="feature-text">像素场景</text>
      </view>
      
      <view class="feature-item">
        <icon type="message" size="24" color="#ff6b35"></icon>
        <text class="feature-text">漂流瓶</text>
      </view>
    </view>
    
    <!-- 服务条款 -->
    <view class="terms">
      <text class="terms-text">登录即表示同意</text>
      <navigator url="/pages/auth/privacy-policy" class="terms-link">
        《用户协议》
      </navigator>
      <text class="terms-text">和</text>
      <navigator url="/pages/auth/terms-of-service" class="terms-link">
        《隐私政策》
      </navigator>
    </view>
  </view>
  
  <!-- 错误提示 -->
  <view class="error-message" wx:if="{{showError}}">
    <text class="error-text">{{errorMessage}}</text>
  </view>
  
  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <loading type="circular" size="24" color="#ff6b35"></loading>
    <text class="loading-text">正在登录...</text>
  </view>
</view>