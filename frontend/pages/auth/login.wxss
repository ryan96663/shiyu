/* 登录页面样式 */
.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
  letter-spacing: 4rpx;
}

.app-slogan {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 1rpx;
}

.login-form {
  width: 100%;
  max-width: 600rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 40rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.wechat-login-btn {
  width: 100%;
  height: 90rpx;
  background: #07c160;
  color: #ffffff;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 30rpx;
  letter-spacing: 2rpx;
}

.wechat-icon {
  margin-right: 12rpx;
}

.wechat-login-btn:active {
  background: #06ad56;
}

.tips {
  text-align: center;
  color: #666666;
  font-size: 24rpx;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.features {
  display: flex;
  justify-content: space-around;
  margin-bottom: 40rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #eeeeee;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feature-text {
  margin-top: 8rpx;
  color: #666666;
  font-size: 24rpx;
}

.terms {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
}

.terms-text {
  color: #999999;
  font-size: 20rpx;
}

.terms-link {
  color: #ff6b35;
  font-size: 20rpx;
  margin: 0 4rpx;
  text-decoration: none;
}

.error-message {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.8);
  color: #ffffff;
  padding: 20rpx 30rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  z-index: 999;
}

.loading {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  padding: 40rpx;
  border-radius: 10rpx;
  z-index: 999;
}

.loading-text {
  margin-top: 20rpx;
  color: #666666;
  font-size: 28rpx;
}

/* 响应式适配 */
@media screen and (max-width: 768px) {
  .login-container {
    padding: 20rpx;
  }
  
  .header {
    margin-bottom: 60rpx;
  }
  
  .login-form {
    padding: 30rpx;
  }
  
  .features {
    flex-direction: column;
    gap: 20rpx;
  }
}