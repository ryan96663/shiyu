/* 扔漂流瓶页面样式 */
.throw-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 顶部导航栏 */
.top-bar {
  height: 80rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 100;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: rgba(255, 107, 53, 0.1);
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  flex: 1;
  text-align: center;
}

.save-btn {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background-color: #ff6b35;
  border-radius: 20rpx;
  color: #ffffff;
  font-size: 24rpx;
}

/* 内容滚动区 */
.content-scroll {
  flex: 1;
  padding-bottom: 120rpx;
}

.form-container {
  padding: 30rpx;
}

/* 区域信息卡片 */
.area-card {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.area-label {
  font-size: 24rpx;
  color: #666666;
  margin-right: 10rpx;
}

.area-value {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

/* 内容输入区 */
.content-section {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.char-count {
  font-size: 20rpx;
  color: #999999;
}

.content-input {
  width: 100%;
  height: 200rpx;
  border: 1rpx solid #eeeeee;
  border-radius: 8rpx;
  padding: 15rpx;
  font-size: 26rpx;
  color: #333333;
  box-sizing: border-box;
  resize: none;
  background-color: #fcfcfc;
}

.content-input:focus {
  border-color: #ff6b35;
  outline: none;
}

/* 快速输入模板 */
.preset-section {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.preset-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 15rpx;
}

.preset-btn {
  padding: 10rpx 16rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 20rpx;
  background-color: #f8f8f8;
  color: #666666;
  font-size: 22rpx;
  white-space: nowrap;
}

.preset-btn:active {
  background-color: #ff6b35;
  color: #ffffff;
  border-color: #ff6b35;
}

/* 问题部分 */
.question-section {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.question-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.question-title {
  display: flex;
  flex-direction: column;
}

.question-desc {
  font-size: 18rpx;
  color: #999999;
  margin-top: 4rpx;
}

.question-input-area {
  border-top: 1rpx solid #eeeeee;
  padding-top: 20rpx;
}

.input-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.input-label {
  font-size: 24rpx;
  color: #666666;
  font-weight: 500;
}

.question-input {
  width: 100%;
  height: 120rpx;
  border: 1rpx solid #eeeeee;
  border-radius: 8rpx;
  padding: 15rpx;
  font-size: 24rpx;
  color: #333333;
  box-sizing: border-box;
  resize: none;
  background-color: #fcfcfc;
}

.question-input:focus {
  border-color: #ff6b35;
  outline: none;
}

/* 标签选择 */
.tag-section {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.tag-desc {
  font-size: 18rpx;
  color: #999999;
  margin-top: 5rpx;
  margin-bottom: 20rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-btn {
  padding: 12rpx 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 20rpx;
  background-color: #ffffff;
  color: #666666;
  font-size: 22rpx;
}

.tag-btn.selected {
  background-color: #ff6b35;
  color: #ffffff;
  border-color: #ff6b35;
}

.tag-btn[disabled] {
  background-color: #f8f8f8;
  color: #cccccc;
  border-color: #e8e8e8;
}

/* 信息说明 */
.info-section {
  background-color: #fff3e0;
  border-left: 4rpx solid #ff6b35;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.info-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #ff6b35;
  margin-bottom: 15rpx;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.info-item {
  font-size: 20rpx;
  color: #666666;
  line-height: 1.4;
}

/* 底部操作区 */
.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ffffff;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.throw-action-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx;
  background-color: #ff6b35;
  border-radius: 25rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 500;
}

/* 提示信息 */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: rgba(0, 0, 0, 0.8);
  color: #ffffff;
  padding: 20rpx 30rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  z-index: 400;
  opacity: 0;
  animation: toastShow 2s ease-in-out;
}

.toast-text {
  color: #ffffff;
  text-align: center;
}

@keyframes toastShow {
  0% { opacity: 0; }
  20% { opacity: 1; }
  80% { opacity: 1; }
  100% { opacity: 0; }
}