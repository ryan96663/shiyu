{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://foodie-social.com/schemas/restaurant-scene-v1.json",
  
  "title": "Restaurant Scene Configuration Schema",
  "description": "Standardized data schema for restaurant scene canvas configuration, following the design document specifications.",
  "version": "1.0.0",
  
  "type": "object",
  "required": ["sceneId", "peopleCount", "tables"],
  "additionalProperties": false,
  
  "properties": {
    
    // 基础场景信息
    "sceneId": {
      "type": "string",
      "description": "Unique scene identifier",
      "pattern": "^[a-zA-Z0-9_-]+$",
      "minLength": 3,
      "maxLength": 50,
      "examples": ["restaurant_preview_001", "sichuan_night_2024"]
    },
    
    "name": {
      "type": "string",
      "description": "Human readable scene name",
      "maxLength": 100
    },
    
    "description": {
      "type": "string", 
      "description": "Scene description for preview",
      "maxLength": 500
    },
    
    // 主题和环境设置
    "theme": {
      "type": "string",
      "description": "Scene theme configuration",
      "enum": ["day_sunny", "day_rainy", "night_sunny", "night_rainy"],
      "default": "day_sunny"
    },
    
    "restaurantType": {
      "type": "string",
      "description": "Type of restaurant for visual styling",
      "enum": ["sichuan", "cantonese", "japanese", "bbq"],
      "default": "sichuan"
    },
    
    "previewMode": {
      "type": "boolean",
      "description": "Whether this is a preview/preview mode scene",
      "default": true
    },
    
    // 布局配置
    "layout": {
      "type": "object",
      "description": "Scene layout configuration",
      "properties": {
        
        "columns": {
          "type": "integer",
          "description": "Number of columns in grid layout",
          "minimum": 2,
          "maximum": 4,
          "default": 3
        },
        
        "tableType": {
          "type": "string",
          "description": "Type of table to use",
          "enum": ["table_2", "table_4", "table_6"],
          "default": "table_4"
        },
        
        "seatAllocationMode": {
          "type": "string",
          "description": "Strategy for seat allocation",
          "enum": ["sequential", "balanced", "social-distance"],
          "default": "sequential"
        },
        
        "enableAnimation": {
          "type": "boolean",
          "description": "Enable person floating animations",
          "default": true
        }
      },
      "additionalProperties": false
    },
    
    // 数据配置
    "peopleCount": {
      "type": "integer",
      "description": "Total number of people to display",
      "minimum": 0,
      "maximum": 200,
      "default": 18
    },
    
    "store": {
      "type": "object",
      "description": "Store information (for preview)",
      "properties": {
        
        "name": {
          "type": "string",
          "description": "Store name",
          "maxLength": 100
        },
        
        "location": {
          "type": "string",
          "description": "Store location description",
          "maxLength": 200
        },
        
        "defaultWeather": {
          "type": "string",
          "enum": ["sunny", "rainy"],
          "default": "sunny"
        },
        
        "openHours": {
          "type": "string",
          "description": "Store opening hours",
          "pattern": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9]-([0-1]?[0-9]|2[0-3]):[0-5][0-9]$"
        }
      },
      "additionalProperties": false
    },
    
    // 桌子列表 - 核心数据
    "tables": {
      "type": "array",
      "description": "Array of table configurations with precise seat allocation",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "required": ["id", "type", "capacity", "seats"],
        "additionalProperties": false,
        
        "properties": {
          
          "id": {
            "type": "string",
            "description": "Unique table identifier",
            "pattern": "^t[0-9]{3,5}$",
            "examples": ["t001", "t012", "t156"]
          },
          
          "type": {
            "type": "string",
            "description": "Table type/capacity",
            "enum": ["table_2", "table_4", "table_6"],
            "default": "table_4"
          },
          
          "capacity": {
            "type": "integer",
            "description": "Maximum capacity of this table",
            "minimum": 2,
            "maximum": 8,
            "default": 4
          },
          
          "currentPeople": {
            "type": "integer",
            "description": "Current number of people at this table",
            "minimum": 0,
            "maximum": 8,
            "default": 0
          },
          
          "status": {
            "type": "string",
            "description": "Current status of the table",
            "enum": ["empty", "occupied", "reserved", "cleaning"],
            "default": "empty"
          },
          
          "canTap": {
            "type": "boolean",
            "description": "Whether this table is interactive",
            "default": true
          },
          
          // 网格布局位置
          "position": {
            "type": "object",
            "description": "Grid position for layout",
            "properties": {
              "row": {
                "type": "integer",
                "description": "Row index (0-based)",
                "minimum": 0
              },
              "col": {
                "type": "integer", 
                "description": "Column index (0-based)",
                "minimum": 0
              },
              "index": {
                "type": "integer",
                "description": "Overall index in table array",
                "minimum": 0
              }
            },
            "required": ["row", "col", "index"],
            "additionalProperties": false
          },
          
          // 座位分配 - 核心特性
          "seats": {
            "type": "object",
            "description": "Detailed seat configuration",
            "required": ["all", "occupied", "empty"],
            "additionalProperties": false,
            
            "properties": {
              
              "all": {
                "type": "array",
                "description": "All available seat positions for this table",
                "minItems": 2,
                "maxItems": 8,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "enum": [
                    "top", "right", "bottom", "left",  // 4人桌
                    "top-left", "top-right",             // 6人桌
                    "bottom-left", "bottom-right"        // 6人桌
                    // 可扩展更多座位位置
                  ]
                }
              },
              
              "occupied": {
                "type": "array",
                "description": "Currently occupied seat positions",
                "uniqueItems": true,
                "items": {
                  "type": "string"
                },
                "default": []
              },
              
              "empty": {
                "type": "array", 
                "description": "Currently empty seat positions",
                "uniqueItems": true,
                "items": {
                  "type": "string"
                },
                "default": []
              },
              
              "count": {
                "type": "object",
                "description": "Quick counts for performance",
                "properties": {
                  "total": { "type": "integer", "minimum": 0 },
                  "occupied": { "type": "integer", "minimum": 0 },
                  "empty": { "type": "integer", "minimum": 0 }
                },
                "additionalProperties": false
              }
            }
          },
          
          // 覆盖设置（用于特殊布局）
          "override": {
            "type": "object",
            "description": "Override settings for special layout requirements",
            "properties": {
              
              "position": {
                "type": ["null", "object"],
                "description": "Override grid position with absolute coordinates",
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" }
                }
              },
              
              "rotation": {
                "type": "number",
                "description": "Table rotation in degrees",
                "minimum": 0,
                "maximum": 360,
                "default": 0
              },
              
              "hidden": {
                "type": "boolean",
                "description": "Whether to hide this table",
                "default": false
              }
            },
            "additionalProperties": false
          },
          
          // 素材资源路径
          "resources": {
            "type": "object",
            "description": "Resource paths for this table",
            "properties": {
              "tableImage": {
                "type": "string",
                "description": "Path to table image",
                "format": "uri-reference"
              },
              "chairImage": {
                "type": "string",
                "description": "Path to chair image",
                "format": "uri-reference"
              },
              "personImage": {
                "type": "string",
                "description": "Path to person image",
                "format": "uri-reference"
              },
              "fallbackImage": {
                "type": "string",
                "description": "Path to fallback/placeholder image",
                "format": "uri-reference"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    
    // 环境效果
    "effects": {
      "type": "object",
      "description": "Environmental effects configuration",
      "properties": {
        
        "weather": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "type": { "type": "string", "enum": ["rain", "snow", "wind"], "default": "rain" },
            "intensity": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.5 }
          }
        },
        
        "lighting": {
          "type": "object",
          "properties": {
            "ceilingLights": { "type": "boolean", "default": true },
            "ambient": { "type": "number", "minimum": 0, "maximum": 1, "default": 1 },
            "contrast": { "type": "number", "minimum": 0, "maximum": 2, "default": 1 }
          }
        },
        
        "animations": {
          "type": "object",
          "properties": {
            "personFloating": { "type": "boolean", "default": true },
            "lightFlicker": { "type": "boolean", "default": false },
            "weatherMotion": { "type": "boolean", "default": true }
          }
        }
      },
      "additionalProperties": false
    },
    
    // 显示设置
    "display": {
      "type": "object",
      "description": "Display and UI configuration",
      "properties": {
        
        "showPreviewBadge": {
          "type": "boolean",
          "description": "Show preview mode badge",
          "default": true
        },
        
        "showTableLabels": {
          "type": "boolean",
          "description": "Show table numbers and occupancy info",
          "default": true
        },
        
        "showLabels": {
          "type": "boolean",
          "description": "Show people count labels",
          "default": true
        },
        
        "enableInteraction": {
          "type": "boolean",
          "description": "Enable table interactions (tap, hover)",
          "default": true
        }
      },
      "additionalProperties": false
    },
    
    // 元数据
    "metadata": {
      "type": "object",
      "description": "Scene metadata and generation info",
      "properties": {
        
        "version": {
          "type": "string",
          "description": "Schema version",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "default": "1.0.0"
        },
        
        "createdAt": {
          "type": "string",
          "description": "Scene creation timestamp",
          "format": "date-time"
        },
        
        "updatedAt": {
          "type": "string",
          "description": "Last update timestamp", 
          "format": "date-time"
        },
        
        "generatedBy": {
          "type": "string",
          "description": "Tool that generated this scene",
          "enum": ["user", "ai", "cli", "api"],
          "default": "user"
        },
        
        "tags": {
          "type": "array",
          "description": "Scene tags for categorization",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "maxLength": 50
          },
          "default": []
        }
      },
      "additionalProperties": false
    }
  },
  
  // 条件验证规则
  "allOf": [
    {
      "if": {
        "properties": { "tableType": { "type": "string", "enum": ["table_2"] } }
      },
      "then": {
        "properties": {
          "tables": {
            "items": {
              "properties": {
                "capacity": { "const": 2 },
                "seats": {
                  "properties": {
                    "all": { "items": { "enum": ["top", "bottom"] } }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "tableType": { "type": "string", "enum": ["table_6"] } }
      },
      "then": {
        "properties": {
          "tables": {
            "items": {
              "properties": {
                "capacity": { "const": 6 },
                "seats": {
                  "properties": {
                    "all": { 
                      "items": { 
                        "enum": ["top", "top-right", "right", "bottom-right", "bottom", "bottom-left", "left", "top-left"] 
                      } 
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}