/* foodie-social/frontend/components/restaurant-canvas/restaurant-canvas.wxss */

.scene-container {
  position: relative;
  width: 100%;
  height: 750rpx; /* 让整个餐厅场景在手机上呈现完美的 1:1 正方形黄金展示区 */
  overflow: hidden;
  background-color: #1a1a1a;
}

.scene-background {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.table-prop {
  position: absolute;
  /* 核心协议：锚点死死锁定在切图的"底部中心" */
  transform: translate(-50%, -100%); 
  transition: transform 0.25s ease-out; /* 预留未来给交互点击时做点Q弹反馈动画 */
}

.table-image {
  /* 【核心修改点】完美匹配你的 80px × 80px 素材比例，防止图片变形 */
  width: 117rpx; 
  height: 117rpx;
  /* 像素风核心CSS：防止微信底层将低画质的像素图片进行模糊抗锯齿，强制保持锐利颗粒感 */
  image-rendering: pixelated; 
}

.desk-badge {
  position: absolute;
  top: -24rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.65);
  color: #ffffff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  white-space: nowrap;
  pointer-events: none; /* 防止桌号文本遮挡了桌子的点击事件 */
  font-family: monospace; /* 像素字体的完美平替 */
}
