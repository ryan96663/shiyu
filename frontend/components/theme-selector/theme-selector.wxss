/* 主题选择器样式 */
.theme-selector {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

/* 遮罩层 */
.theme-selector-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
}

/* 主要内容 */
.theme-selector-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 20px 20px 0 0;
  box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

/* 头部 */
.theme-selector-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 24px 16px;
  border-bottom: 1px solid #f0f0f0;
  background-color: #fafafa;
}

.theme-selector-title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
}

.theme-selector-close {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #f0f0f0;
  transition: all 0.2s;
}

.theme-selector-close:hover {
  background-color: #e0e0e0;
}

.close-icon {
  font-size: 14px;
  color: #666;
}

/* 主体内容 */
.theme-selector-body {
  padding: 0 0 20px;
}

/* 主题列表 */
.theme-list {
  padding: 0 24px;
}

.theme-item {
  display: flex;
  align-items: center;
  padding: 16px 8px;
  border-radius: 12px;
  transition: all 0.2s;
  cursor: pointer;
  margin-bottom: 12px;
  border: 2px solid transparent;
}

.theme-item:last-child {
  margin-bottom: 0;
}

.theme-item--active {
  background-color: #f8f9ff;
  border-color: #007AFF;
  box-shadow: 0 2px 8px rgba(0, 122, 255, 0.1);
}

.theme-item--hover {
  background-color: #f5f5f5;
}

.theme-item.theme-item--active:hover {
  background-color: #f0f1ff;
}

/* 主题图标 */
.theme-icon {
  width: 56px;
  height: 56px;
  margin-right: 16px;
  flex-shrink: 0;
}

.theme-icon-image {
  width: 100%;
  height: 100%;
  border-radius: 12px;
  object-fit: cover;
}

.theme-icon-preview {
  width: 100%;
  height: 100%;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

/* 主题信息 */
.theme-info {
  flex: 1;
  margin-right: 12px;
}

.theme-name {
  font-size: 16px;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 4px;
}

.theme-description {
  font-size: 13px;
  color: #888;
  display: block;
  line-height: 1.3;
}

/* 选中状态 */
.theme-check {
  width: 24px;
  height: 24px;
  background-color: #007AFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.check-icon {
  color: #fff;
  font-size: 12px;
  font-weight: bold;
}

/* 操作按钮组 */
.theme-actions {
  display: flex;
  justify-content: center;
  gap: 16px;
  padding: 20px 24px 0;
  border-top: 1px solid #f0f0f0;
  margin-top: 20px;
}

.btn {
  min-width: 80px;
  height: 36px;
  border: none;
  border-radius: 18px;
  font-size: 14px;
  font-weight: 500;
  transition: all 0.2s;
  cursor: pointer;
}

.btn-primary {
  background-color: #007AFF;
  color: #fff;
}

.btn-primary:active {
  background-color: #0056CC;
  transform: scale(0.98);
}

.btn-secondary {
  background-color: #f0f0f0;
  color: #666;
}

.btn-secondary:active {
  background-color: #e0e0e0;
  transform: scale(0.98);
}

/* 动画状态 */
.theme-item--active .theme-name {
  color: #007AFF;
  font-weight: 600;
}

.theme-item--active .theme-description {
  color: #0056CC;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .theme-selector-content {
    border-radius: 16px 16px 0 0;
  }
  
  .theme-selector-header {
    padding: 16px 20px 12px;
  }
  
  .theme-selector-title {
    font-size: 16px;
  }
  
  .theme-list {
    padding: 0 20px;
  }
  
  .theme-item {
    padding: 14px 8px;
  }
  
  .theme-icon {
    width: 48px;
    height: 48px;
  }
  
  .theme-actions {
    padding: 16px 20px 0;
  }
}